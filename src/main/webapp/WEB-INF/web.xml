<?xml version="1.0" encoding="UTF-8"?>
<web-app xmlns="http://xmlns.jcp.org/xml/ns/javaee"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="http://xmlns.jcp.org/xml/ns/javaee
         http://xmlns.jcp.org/xml/ns/javaee/web-app_4_0.xsd"
         version="4.0">

    <display-name>Face Recognition Attendance System</display-name>

    <!-- 欢迎页面 -->
    <welcome-file-list>
        <welcome-file>jsp/login.jsp</welcome-file>
    </welcome-file-list>

    <!-- 会话超时 30分钟 -->
    <session-config>
        <session-timeout>30</session-timeout>
    </session-config>

    <!-- ==================== 用户相关 Servlet ==================== -->
    <servlet>
        <servlet-name>LoginServlet</servlet-name>
        <servlet-class>com.face.servlet.LoginServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>LoginServlet</servlet-name>
        <url-pattern>/login</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>RegisterServlet</servlet-name>
        <servlet-class>com.face.servlet.RegisterServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>RegisterServlet</servlet-name>
        <url-pattern>/register</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>LogoutServlet</servlet-name>
        <servlet-class>com.face.servlet.LogoutServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>LogoutServlet</servlet-name>
        <url-pattern>/logout</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>ProfileServlet</servlet-name>
        <servlet-class>com.face.servlet.ProfileServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>ProfileServlet</servlet-name>
        <url-pattern>/profile</url-pattern>
    </servlet-mapping>

    <!-- ==================== 人脸相关 Servlet ==================== -->
    <servlet>
        <servlet-name>FaceRegisterServlet</servlet-name>
        <servlet-class>com.face.servlet.FaceRegisterServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>FaceRegisterServlet</servlet-name>
        <url-pattern>/faceRegister</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>CheckinServlet</servlet-name>
        <servlet-class>com.face.servlet.CheckinServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>CheckinServlet</servlet-name>
        <url-pattern>/checkin</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>FaceLoginServlet</servlet-name>
        <servlet-class>com.face.servlet.FaceLoginServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>FaceLoginServlet</servlet-name>
        <url-pattern>/faceLogin</url-pattern>
    </servlet-mapping>

    <!-- ==================== 考勤记录 Servlet ==================== -->
    <servlet>
        <servlet-name>AttendanceServlet</servlet-name>
        <servlet-class>com.face.servlet.AttendanceServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>AttendanceServlet</servlet-name>
        <url-pattern>/attendance</url-pattern>
    </servlet-mapping>

    <!-- ==================== 管理员 Servlet ==================== -->
    <servlet>
        <servlet-name>UserManageServlet</servlet-name>
        <servlet-class>com.face.servlet.UserManageServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>UserManageServlet</servlet-name>
        <url-pattern>/admin/userManage</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>AdminAttendanceServlet</servlet-name>
        <servlet-class>com.face.servlet.AdminAttendanceServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>AdminAttendanceServlet</servlet-name>
        <url-pattern>/admin/attendance</url-pattern>
    </servlet-mapping>

    <!-- ==================== 权限过滤器 ==================== -->
    <filter>
        <filter-name>AuthFilter</filter-name>
        <filter-class>com.face.filter.AuthFilter</filter-class>
    </filter>
    <filter-mapping>
        <filter-name>AuthFilter</filter-name>
        <url-pattern>/*</url-pattern>
    </filter-mapping>

    <!-- ==================== 错误页面 ==================== -->
    <error-page>
        <error-code>404</error-code>
        <location>/jsp/error/404.jsp</location>
    </error-page>
    <error-page>
        <error-code>500</error-code>
        <location>/jsp/error/500.jsp</location>
    </error-page>

</web-app>
